# Server Configuration
PORT=4000
NODE_ENV=development

# Tenant Database (Multi-tenant CRM data)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/tenant-db

# Master Database (Shared global data)
DATA_CENTER_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/master-database

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Encryption Key for User Settings (32 characters minimum)
ENCRYPTION_KEY=your-32-character-encryption-key

# SAAS Owner Credentials (for initial setup)
SAAS_OWNER_EMAIL=admin@saasplatform.com
SAAS_OWNER_PASSWORD=changethispassword

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend URL
FRONTEND_URL=http://localhost:3000

# AWS Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-s3-bucket-name

# AWS SQS (Email Queue - Optional)
AWS_SQS_QUEUE_URL=your-sqs-queue-url

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Configuration (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourcompany.com

# IMAP Configuration (Email Integration - Optional)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password

# OpenAI API (Optional - for AI features)
OPENAI_API_KEY=your_openai_api_key

# Payment Gateway (Optional)
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret
